# Financial Modeling Prep API (free tier: 250 req/day)
# Get your key at https://financialmodelingprep.com/developer
FMP_API_KEY=your_fmp_api_key_here

# API-Ninjas (free tier: 10,000 req/month)
# Get your key at https://api-ninjas.com
API_NINJAS_KEY=your_api_ninjas_key_here

# Database path (default: ./earnings.db for local, /tmp/earnings.db on Vercel)
# DATABASE_PATH=./earnings.db

# Set to 'true' to force re-seed on next startup
# FORCE_RESEED=false
